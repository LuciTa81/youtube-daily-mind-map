{
  "name": "youtube-daily-mind-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "android:sync": "node ./node_modules/next/dist/bin/next build && node ./node_modules/@capacitor/cli/bin/capacitor sync android",
    "android:debug": "node ./node_modules/next/dist/bin/next build && node ./node_modules/@capacitor/cli/bin/capacitor sync android && cd android && gradlew assembleDebug",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --max-warnings=0",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "smoke:import-surface": "node scripts/smoke-import-surface.mjs",
    "smoke:large-takeout": "node scripts/smoke-large-takeout.mjs",
    "verify": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/eslint/bin/eslint.js . --max-warnings=0 && node ./node_modules/vitest/vitest.mjs run && node ./node_modules/next/dist/bin/next build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@xyflow/react": "^12.4.4",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jszip": "^3.10.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
