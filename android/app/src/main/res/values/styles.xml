<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:navigationBarColor">#f1f5f9</item>
        <item name="android:statusBarColor">#f1f5f9</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0f172a</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:windowBackground">#0f172a</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowAnimationStyle">@style/AppTheme.NoActionBarLaunch.Animation</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch.Animation">
        <item name="android:activityOpenEnterAnimation">@anim/quick_share_noop</item>
        <item name="android:activityOpenExitAnimation">@anim/quick_share_noop</item>
        <item name="android:activityCloseEnterAnimation">@anim/quick_share_noop</item>
        <item name="android:activityCloseExitAnimation">@anim/quick_share_noop</item>
    </style>
</resources>
